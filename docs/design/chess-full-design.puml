@startuml
title Class Diagram for Chess Game

package ui {

    +class Main {
        +{static} main(args: String[]): void
    }

    +class WelcomeController {
        -welcomeView: WelcomeView

        +WelcomeController()
        +show(): void
        ~getWelcomeView(): WelcomeView

        -startGame(): void
        -selectedInitializer(): BoardInitializer
        -closeWelcomeView(): void
    }

    +class WelcomeView {
        -player1NameField: JTextField
        -player2NameField: JTextField
        -standardRadioButton: JRadioButton
        -chess960RadioButton: JRadioButton
        -errorLabel: JLabel

        +WelcomeView()
        +getPlayer1Name(): String
        +getPlayer2Name(): String
        +isChess960Selected(): boolean
        +setChess960Selected(selected: boolean): void
        +setStartGameAction(action: Runnable): void
        +showError(message: String): void
        +getErrorText(): String
        ~clickStartGame(): void
        -createWelcomeScreenUI(): void
    }

    +class MainView {
        -boardController: BoardController
        -boardView: BoardView
        -gameStatsView: GameStatsView

        +MainView(player1Name: String, player2Name: String, boardController: BoardController)
        +getGameStatsView(): GameStatsView
        -configureMainView(): void
        -addGameStatsView(): void
        -addBoardView(): void
    }

    +class GameStatsView {
        -currentPlayerLabel: JLabel

        +GameStatsView(player1Name: String, player2Name: String)
        +updateCurrentPlayerLabel(playerName: String): void
    }

    +class BoardView {
        -{static}{final} BOARD_SIZE: int
        -{static}{final} TILE_SIZE: int
        -{static}{final} LIGHT_SQUARE_COLOR: Color
        -{static}{final} DARK_SQUARE_COLOR: Color
        -{static}{final} SELECTED_SQUARE_COLOR: Color
        -{static}{final} LEGAL_MOVE_DOT_COLOR: Color
        -{static}{final} LEGAL_CAPTURE_COLOR: Color
        -{static}{final} LEGAL_MOVE_ALPHA: float

        -whitePieceImages: Map<PieceType, Image>
        -blackPieceImages: Map<PieceType, Image>
        -boardController: BoardController

        +BoardView(boardController: BoardController)
        #paintComponent(g: Graphics): void
        -drawBoard(g: Graphics): void
        -drawSelectedSquare(g: Graphics): void
        -drawLegalMoveHighlights(g: Graphics): void
        -drawPieces(g: Graphics): void
        -loadPieceImages(): void
        -loadOnePieceImage(pieceType: PieceType, color: PieceColor, imagePath: String): void
    }

    -class BoardMouseListener {
        +mousePressed(e: MouseEvent): void
    }

    +class BoardController {
        -{static}{final} BOARD_SIZE: int
        -player1Name: String
        -player2Name: String
        -board: Board
        -boardView: BoardView
        -mainView: MainView
        -lastSelectedLoc: Optional<Location>

        +BoardController(player1Name: String, player2Name: String, board: Board)
        +show(): void
        +setBoardView(boardView: BoardView): void
        ~getBoardView(): BoardView
        ~getMainView(): MainView
        +handleSquareClick(loc: Location): void
        +hasSelection(): boolean
        +getSelectedLocation(): Optional<Location>
        +getLegalMovesForSelection(): List<Move>
        +getBoardSnapshot(): Piece[][]
        +getCurrentGameState(): GameState

        -handleSourceClick(loc: Location, currentColor: PieceColor): void
        -handleDestinationClick(dest: Location, currentColor: PieceColor): void
        -executeMove(move: Move, currentColor: PieceColor): void
        -findMoveToDestination(moves: List<Move>, dest: Location): Optional<Move>
        -promptForPromotionPiece(color: PieceColor): PieceType
        -isGameOver(): boolean
        -showEndGame(): void
        -buildEndGameMessage(): String
        -updateCurrentPlayerLabel(): void
        -repaintBoardView(): void
        -{static} isInBounds(loc: Location): boolean
    }

    note right of BoardController::handleSquareClick
        Dispatches to handleSourceClick when no piece is
        selected, or handleDestinationClick when one is.
        handleDestinationClick validates the destination
        against getLegalMoves, then calls executeMove.
        executeMove prompts for promotion if needed, calls
        board.makeMove, and triggers showEndGame if the
        game state becomes terminal.
    end note

    ~class PromotionDialog {
        -dialog: JDialog
        -color: PieceColor
        -chosenType: PieceType

        ~PromotionDialog(parent: JFrame, color: PieceColor)
        ~showAndGetChoice(): PieceType
        -buildUi(): void
        -buildPromotionButton(type: PieceType): JButton
        -loadImage(type: PieceType): Image
    }

    ~class EndGameView {
        ~EndGameView(resultMessage: String)
        ~setPlayAgainAction(action: Runnable): void
        ~clickPlayAgain(): void
        -buildUi(resultMessage: String): void
    }

    ~class EndGameController {
        -endGameView: EndGameView
        -mainView: JFrame

        ~EndGameController(resultMessage: String, mainView: JFrame)
        ~show(): void
        -playAgain(): void
    }

}

package domain {

    package move {

        +class Move {
            -{final} from: Location
            -{final} to: Location
            -{final} type: MoveType
            -{final} promotionType: Optional<PieceType>

            +Move(from: Location, to: Location)
            +Move(from: Location, to: Location, type: MoveType)
            +Move(from: Location, to: Location, type: MoveType, promotionPiece: PieceType)
            +getFrom(): Location
            +getTo(): Location
            +getType(): MoveType
            +getPromotionType(): Optional<PieceType>
            +withPromotionType(piece: PieceType): Move
        }

        +enum MoveType {
            NORMAL
            EN_PASSANT
            CASTLING_KINGSIDE
            CASTLING_QUEENSIDE
            PROMOTION
        }

    }

    package piece {

        +enum PieceColor {
            WHITE
            BLACK
        }

        +enum PieceType {
            NONE
            PAWN
            ROOK
            KNIGHT
            BISHOP
            QUEEN
            KING
        }

        +abstract class Piece {
            -{final} type: PieceType
            -{final} color: PieceColor
            -{final} canJump: boolean
            -hasMoved: boolean

            +Piece(type: PieceType, color: PieceColor, canJump: boolean)
            +getType(): PieceType
            +getColor(): PieceColor
            +isSameColor(piece: Piece): boolean
            +canJump(): boolean
            +hasMoved(): boolean
            +changeToMoved(): void
            +resetHasMoved(): void
            +toString(): String
            +{abstract} makeCopy(): Piece
            +{abstract} isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Bishop {
            +Bishop(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class King {
            +King(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Knight {
            +Knight(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Pawn {
            +Pawn(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Queen {
            +Queen(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Rook {
            +Rook(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class NonePiece {
            +NonePiece()
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
            +isSameColor(piece: Piece): boolean
        }

    }

    +interface BoardInitializer {
        +getBoardLayout(): PieceType[][]
    }

    +class StandardBoardInitializer {
        +getBoardLayout(): PieceType[][]
    }

    +class FischerRandomBoardInitializer {
        -random: Random
        +FischerRandomBoardInitializer(random: Random)
        +getBoardLayout(): PieceType[][]
    }

    +class Board {
        -{static}{final} BOARD_SIZE: int
        -pieces: Piece[][]
        -currentGameState: GameState
        -enPassantTarget: Optional<Location>
        -halfMoveClock: int

        +Board(initializer: BoardInitializer)
        +Board(initialPieces: Piece[][])
        +getCurrentGameState(): GameState
        +getPieceAt(rank: int, file: int): Piece
        +getSnapshot(): Piece[][]
        +getEnPassantTarget(): Optional<Location>
        +getLegalMoves(from: Location): List<Move>
        +makeMove(move: Move): void

        -currentPlayerColor(): PieceColor
        -isCapture(move: Move): boolean
        -applyMoveToInternalState(move: Move): void
        -executeCastling(rank: int, kingFile: int, kingDestFile: int, rookDestFile: int, kingside: boolean): void
        -findCastlingRookFile(rank: int, kingFile: int, kingside: boolean): int
        -updateEnPassantTarget(move: Move, movedPiece: Piece): void
        -updateGameState(justMovedColor: PieceColor): void
        -isInsufficientMaterial(): boolean
    }

    note left of Board::makeMove
        Applies the move via applyMoveToInternalState,
        then updates enPassantTarget and halfMoveClock,
        then calls updateGameState which sets currentGameState
        to WHITE_TURN, BLACK_TURN, WHITE_WIN, BLACK_WIN, or DRAW.
        Draw conditions: stalemate, insufficient material,
        fifty-move rule.
    end note

    +class MoveGenerator {
        -{static}{final} BOARD_SIZE: int
        -board: Piece[][]
        -enPassantTarget: Optional<Location>

        +MoveGenerator(board: Piece[][], enPassantTarget: Optional<Location>)
        +generateLegalMoves(from: Location): List<Move>
        +generateAllLegalMovesForColor(color: PieceColor): List<Move>
        +hasLegalMovesForColor(color: PieceColor): boolean
        +isInCheck(color: PieceColor): boolean

        ~{static} applyMoveToBoard(original: Piece[][], move: Move): Piece[][]
        ~{static} isSquareAttackedBy(square: Location, attackerColor: PieceColor, board: Piece[][]): boolean
        ~{static} findKing(color: PieceColor, board: Piece[][]): Location
        ~{static} createPiece(type: PieceType, color: PieceColor): Piece
        ~{static} opponent(color: PieceColor): PieceColor
    }

    note right of MoveGenerator::generateLegalMoves
        Generates pseudo-legal moves for the piece at 'from',
        then filters out any that leave the moving side's king
        in check (via applyMoveToBoard + isInCheck simulation).
        Special moves: en passant, castling (kingside and
        queenside), and promotion candidates for pawns
        reaching the back rank.
    end note

    +enum GameState {
        WHITE_TURN
        BLACK_TURN
        WHITE_WIN
        BLACK_WIN
        DRAW
    }

    +class Location {
        -{final} x: int
        -{final} y: int

        +Location(x: int, y: int)
        +getX(): int
        +getY(): int
    }

}

package java {
    +class JFrame {}
    +class JPanel {}
    +class Color {}
    +class Image {}
    +class Graphics {}
    +class MouseAdapter {}
}

' --- Entry point ---
Main ..> WelcomeController

' --- WelcomeController ---
WelcomeController --> WelcomeView
WelcomeController ..> BoardController
WelcomeController ..> Board
WelcomeController ..> BoardInitializer

' --- View inheritance ---
WelcomeView -u-|> JFrame
MainView -u-|> JFrame
EndGameView -u-|> JFrame
GameStatsView -u-|> JPanel
BoardView -u-|> JPanel
BoardMouseListener -u-|> MouseAdapter

' --- MainView ---
MainView --> BoardController
MainView --> BoardView
MainView --> GameStatsView

' --- BoardView ---
BoardView --> "3" Color
BoardView --> "*" PieceType
BoardView --> "*" Image
BoardView --> BoardController
BoardView ..> Graphics
BoardView ..> Move
BoardView --+ BoardMouseListener

' --- BoardController ---
BoardController --> Board
BoardController --> BoardView
BoardController --> MainView
BoardController ..> Move
BoardController ..> MoveType
BoardController ..> Location
BoardController ..> Piece
BoardController ..> PieceType
BoardController ..> PieceColor
BoardController ..> GameState
BoardController ..> PromotionDialog
BoardController ..> EndGameController

' --- EndGameController ---
EndGameController --> EndGameView
EndGameController ..> WelcomeController

' --- Board ---
Board --> "64" Piece
Board --> GameState
Board ..> Move
Board ..> Location
Board ..> MoveGenerator
Board ..> PieceColor
Board ..> PieceType
Board ..> NonePiece
Board ..> BoardInitializer

' --- MoveGenerator ---
MoveGenerator ..> Move
MoveGenerator ..> MoveType
MoveGenerator ..> Location
MoveGenerator ..> Piece
MoveGenerator ..> PieceColor
MoveGenerator ..> PieceType
MoveGenerator ..> NonePiece
MoveGenerator ..> Bishop
MoveGenerator ..> King
MoveGenerator ..> Knight
MoveGenerator ..> Pawn
MoveGenerator ..> Queen
MoveGenerator ..> Rook

' --- Move ---
Move --> Location
Move --> MoveType
Move ..> PieceType

' --- Initializers ---
StandardBoardInitializer ..|> BoardInitializer
FischerRandomBoardInitializer ..|> BoardInitializer

' --- Piece hierarchy ---
Bishop -u-|> Piece
King -u-|> Piece
Knight -u-|> Piece
NonePiece -u-|> Piece
Pawn -u-|> Piece
Queen -u-|> Piece
Rook -u-|> Piece

' --- Piece internals ---
Piece --> PieceType
Piece --> PieceColor
Piece ..> Location

@enduml
