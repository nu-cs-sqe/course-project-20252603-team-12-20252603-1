  }
  +class MouseAdapter{
  }
}

Main ..> WelcomeView

WelcomeView -u-|> JFrame

MainView -u-|> JFrame
MainView --> BoardView
MainView --> BoardController
MainView --> GameStatsView

GameStatsView -u-|> JPanel
GameStatsView --> GameState

BoardView -u-|> JPanel
BoardView --> "3" Color
BoardView --> "*" PieceType
BoardView --> "*" Image
BoardView --> BoardController
BoardView ..> Graphics
BoardView --+ BoardMouseListener

BoardMouseListener -u-|> MouseAdapter

BoardController --> BoardView
BoardController --> Board
BoardController ..> Location
BoardController ..> Piece

Bishop -u-|> Piece
King -u-|> Piece
Knight -u-|> Piece
Pawn -u-|> Piece
Queen -u-|> Piece
Rook -u-|> Piece

Board --> "64" Piece
Board ..> Bishop
Board ..> King
Board ..> Knight
Board ..> Pawn
Board ..> Queen
