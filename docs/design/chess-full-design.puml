@startuml
title Class Diagram for Chess Game

package ui{

    +class Main{
        +{static} main(args: String[]): void
    }

    +class AppController{
        -currentFrame: JFrame

        +AppController()
        +start(): void
        -onGameStart(player1Name: String, player2Name: String, isChess960: boolean): void
        -onGameOver(result: GameState): void
        -onPlayAgain(): void
        -transitionTo(frame: JFrame): void
    }

    note right of AppController
        Constructor creates and wires the initial WelcomeView,
        storing it in currentFrame so the field is never absent.
        start() makes currentFrame visible (called once from Main).
        All subsequent screen changes go through transitionTo(),
        which disposes the current frame and shows the new one.
        Views fire callbacks; AppController decides what to show next.
    end note

    +class WelcomeView{
        -player1NameField: JTextField
        -player2NameField: JTextField
        -standardRadioButton: JRadioButton
        -chess960RadioButton: JRadioButton

        +WelcomeView()
        +getPlayer1Name(): String
        +getPlayer2Name(): String
        +isChess960Selected(): boolean
        +setStartGameAction(action: Runnable): void
        ~clickStartGame(): void
        -createWelcomeScreenUI(): void
    }

    +class EndGameView{
        +EndGameView(result: GameState)
        +setPlayAgainAction(action: Runnable): void
        -createEndGameUI(): void
    }

    +class MainView{
        -boardController: BoardController
        -boardView: BoardView
        -gameStatsView: GameStatsView

        +MainView(player1Name: String, player2Name: String, board: Board)
        +setGameOverAction(action: Consumer<GameState>): void
        -configureMainView(): void
        -addGameStatsView(): void
        -addBoardView(): void
        -registerBoardViewWithController(): void
    }

    +class GameStatsView{
        -{static}{final} MATCHUP_SEPARATOR: String
        -currentPlayerLabel: JLabel
        -gameStateLabel: JLabel

        +GameStatsView(player1Name: String, player2Name: String)
        +updateCurrentPlayerLabel(playerName: String): void
        +updateGameStateLabel(gameState: GameState): void
    }

    +class BoardView{
        -{static}{final} BOARD_SIZE: int
        -{static}{final} TILE_SIZE: int
        -{static}{final} LIGHT_SQUARE_COLOR: Color
        -{static}{final} DARK_SQUARE_COLOR: Color
        -{static}{final} SELECTED_SQUARE_COLOR: Color

        -whitePieceImages: Map<PieceType, Image>
        -blackPieceImages: Map<PieceType, Image>

        -boardController: BoardController

        +BoardView(boardController: BoardController)
        #paintComponent(g: Graphics): void

        -drawBoard(g: Graphics): void
        -loadPieceImages(): void
        -loadOnePieceImage(pieceType: PieceType, color: PieceColor, imagePath: String): void
        -drawPieces(g: Graphics): void
        -drawSelectedSquare(g: Graphics): void
    }

    -class BoardMouseListener{
        +mouseClicked(e: MouseEvent): void
    }

    +class BoardController{
        -{static}{final} BOARD_SIZE: int
        -board: Board
        -boardView: BoardView
        -lastSelectedLoc: Optional<Location>
        -gameOverAction: Consumer<GameState>

        +BoardController(board: Board)
        +setBoardView(boardView: BoardView): void
        +setGameOverAction(action: Consumer<GameState>): void

        +handleSquareClick(loc: Location): void
        -determineAction(loc: Location): void

        +hasSelection(): boolean
        +getSelectedLocation(): Optional<Location>
        +getBoardSnapshot(): Piece[][]
        +getCurrentGameState(): GameState

        -repaintBoardView(): void
        -{static} isInBounds(loc: Location): boolean
    }

    note right of BoardController::determineAction
        A click can be:
        1) selecting a piece to move
        2) choosing the destination for a previously selected piece
        3) invalid selection (empty square or opponent's piece)
        4) part of a castling action

        After a move, checks getCurrentGameState().
        If terminal (WHITE_WIN / BLACK_WIN / DRAW), fires gameOverAction.
    end note

}

package domain{

    package piece{
        +enum PieceColor{
            WHITE,
            BLACK
        }

        +enum PieceType{
            NONE,
            PAWN,
            ROOK,
            KNIGHT,
            BISHOP,
            QUEEN,
            KING
        }

        +abstract class Piece{
            -{final} type: PieceType
            -{final} color: PieceColor
            -{final} canJump: boolean
            -hasMoved: boolean

            +Piece(type: PieceType, color: PieceColor)

            +getType(): PieceType
            +getColor(): PieceColor

            +isSameColor(piece: Piece): boolean
            +canJump(): boolean
            +hasMoved(): boolean

            +changeToMoved(): void
            +resetHasMoved(): void

            +toString(): String

            +{abstract}makeCopy(): Piece
            +{abstract}isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Bishop{
            +Bishop(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class King{
            +King(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Knight{
            +Knight(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Pawn{
            +Pawn(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Queen{
            +Queen(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class Rook{
            +Rook(color: PieceColor)
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
        }

        +class NonePiece{
            +NonePiece()
            +makeCopy(): Piece
            +isValidMoveShape(from: Location, to: Location): boolean
            +isSameColor(piece: Piece): boolean
        }
    }

    +interface BoardInitializer{
        +getBoardLayout(): PieceType[][]
    }

    +class StandardBoardInitializer{
        +getBoardLayout(): PieceType[][]
    }

    +class FischerRandomBoardInitializer{
        -random: Random
        +FischerRandomBoardInitializer(random: Random)
        +getBoardLayout(): PieceType[][]
    }

    +class Board{
        -{static}{final} BOARD_SIZE: int
        -{static}{final} BLACK_RANK_ROWS: int
        -pieces: Piece[][]
        -currentGameState: GameState

        +Board(initialPieces: Piece[][])
        +Board(initializer: BoardInitializer)

        +getCurrentGameState(): GameState
        +getPieceAt(rank: int, file: int): Piece
        +getSnapshot(): Piece[][]

        +movePiece(from: Location, to: Location): boolean
        -isDestinationNotSameColor(from: Location, to: Location): boolean
        -isMoveValidShape(from: Location, to: Location): boolean
        -hasNoObstacle(from: Location, to: Location): boolean
        -checkNotMoveIntoCheck(from: Location, to: Location): boolean

        +promotePawn(location: Location, newPieceType: PieceType): boolean
        +castle(kingFrom: Location, kingTo: Location, rookFrom: Location, rookTo: Location): boolean

        +switchTurn(): void
        -updateGameState(): void
        -checkCheckmate(): void
        -checkStalemate(): void
    }

    note left of Board::movePiece
        Returns true if move succeeded.
        Calls in order: isDestinationNotSameColor,
        isMoveValidShape, hasNoObstacle,
        checkNotMoveIntoCheck.
        On success, calls updateGameState().
    end note

    +enum GameState{
        WHITE_TURN
        BLACK_TURN
        WHITE_WIN
        BLACK_WIN
        DRAW
    }

    +class Location{
        -{final} x: int
        -{final} y: int

        +Location(x: int, y: int)
        +getX(): int
        +getY(): int
    }

}

package java{
  +class JFrame{
  }
  +class JPanel{
  }
  +class Color{
  }
  +class Image{
  }
  +class Graphics{
  }
  +class MouseAdapter{
  }
}

' --- Entry point ---
Main ..> AppController

' --- AppController wires all screen transitions ---
AppController --> WelcomeView
AppController --> MainView
AppController --> EndGameView
AppController ..> Board
AppController ..> BoardInitializer
AppController ..> GameState

' --- View inheritance ---
WelcomeView -u-|> JFrame
EndGameView -u-|> JFrame
MainView -u-|> JFrame
GameStatsView -u-|> JPanel
BoardView -u-|> JPanel
BoardMouseListener -u-|> MouseAdapter

' --- MainView internal composition ---
MainView --> BoardController
MainView --> BoardView
MainView --> GameStatsView

' --- BoardView ---
BoardView --> "3" Color
BoardView --> "*" PieceType
BoardView --> "*" Image
BoardView --> BoardController
BoardView ..> Graphics
BoardView --+ BoardMouseListener

' --- BoardController ---
BoardController --> Board
BoardController ..> Location
BoardController ..> Piece
BoardController ..> GameState

' --- GameStatsView ---
GameStatsView ..> GameState

' --- Piece hierarchy ---
Bishop -u-|> Piece
King -u-|> Piece
Knight -u-|> Piece
NonePiece -u-|> Piece
Pawn -u-|> Piece
Queen -u-|> Piece
Rook -u-|> Piece

' --- Board and initializers ---
StandardBoardInitializer ..|> BoardInitializer
FischerRandomBoardInitializer ..|> BoardInitializer
Board ..> BoardInitializer
Board --> "64" Piece
Board ..> Bishop
Board ..> King
Board ..> Knight
Board ..> NonePiece
Board ..> Pawn
Board ..> Queen
Board ..> Rook
Board ..> PieceColor
Board --> GameState

' --- Piece internals ---
Piece --> PieceType
Piece --> PieceColor
Piece ..> Location

@enduml
